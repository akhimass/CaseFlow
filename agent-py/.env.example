OPENAI_FALLBACK_MODEL=openai/gpt-4.1-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=400
LIVEKIT_INFERENCE_MODEL=openai/gpt-5.2-chat-latest

