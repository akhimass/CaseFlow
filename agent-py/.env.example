# MiniMax TTS only (no STT on LiveKit Inference)
MINIMAX_API_KEY=
MINIMAX_TTS_MODEL=speech-02-hd
MINIMAX_VOICE_ID_ES=
MINIMAX_VOICE_ID_EN=English_SereneWoman

# Live intake dialogue — TrueFoundry primary, LiveKit Inference fallback when keys unset
LLM_PROVIDER=truefoundry
