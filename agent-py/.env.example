# Real OpenAI account (sk-...) used DIRECTLY at api.openai.com so your own
# credits/rate limits apply, bypassing the rate-limited TrueFoundry-routed org.
# Leave blank to keep routing only through TrueFoundry + Bedrock failover.
OPENAI_DIRECT_API_KEY=
OPENAI_DIRECT_MODEL=gpt-4.1-mini

# Dialogue LLM provider order. "minimax" (default) uses MiniMax-Text-01 first
# (tool calling, no reasoning tokens in speech). Alternatives: bedrock | openai |
# truefoundry. Bedrock is reliable when OpenAI free-tier (50 req/day) is exhausted.
DIALOGUE_PRIMARY=minimax

# MiniMax as the dialogue LLM (OpenAI-compatible, supports tool calling, uses the
# same key as MiniMax TTS). MiniMax-Text-01 has no <think> tokens and is fast.
MINIMAX_LLM_MODEL=MiniMax-Text-01
MINIMAX_LLM_BASE_URL=https://api.minimax.io/v1
