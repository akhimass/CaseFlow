# Moss — semantic search / memory (https://docs.moss.dev/docs)
# MOSS_PROJECT_ID / MOSS_PROJECT_KEY are filled in at index/run time (Task 9).
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
# Four separate knowledge indexes (one per retrieval stream) + per-user memory.
MOSS_STATE_LAW_INDEX=state-law
MOSS_SETTLEMENTS_INDEX=settlements
MOSS_FIRMS_INDEX=firms
MOSS_PROCEDURES_INDEX=procedures
MOSS_MEMORY_INDEX_NAME=memory
# Higher-accuracy embeddings for bilingual ES/EN legal text; memory stays fast.
MOSS_KNOWLEDGE_MODEL_ID=moss-mediumlm
MOSS_MEMORY_MODEL_ID=moss-minilm

LLM_PROVIDER=truefoundry
OPENAI_BASE_URL=https://gateway.truefoundry.ai/api/llm/openai
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4o
TRUEFOUNDRY_GATEWAY_URL=https://gateway.truefoundry.ai/api/llm/openai
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_MODEL=openai/gpt-4o
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=400
LLM_STREAMING=true

# Direct OpenAI fallback (used only if TrueFoundry errors or times out)
OPENAI_API_KEY=
OPENAI_FALLBACK_MODEL=gpt-4o

# Unsiloed document parsing
UNSILOED_API_KEY=

# Firm dashboard case broadcast target
CASEFLOW_API_URL=http://localhost:3000

# Deepgram STT (direct API — primary transcription for bilingual intake)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi
DEEPGRAM_DETECT_LANGUAGE=false
# Fallback when DEEPGRAM_API_KEY is unset (LiveKit Inference)
