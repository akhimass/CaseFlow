# Enviroment variables needed to connect to the LiveKit server.
LIVEKIT_API_KEY=<your_api_key>
LIVEKIT_API_SECRET=<your_api_secret>
LIVEKIT_URL=wss://<project-subdomain>.livekit.cloud

# Agent dispatch (https://docs.livekit.io/agents/server/agent-dispatch)
# Leave AGENT_NAME blank to enable automatic dispatch
# Provide an agent name to enable explicit dispatch.
# Caseflow dispatches explicitly to the Python agent registered as `caseflow-agent`.
AGENT_NAME=caseflow-agent

# Supabase — Caseflow uses the FirstCall project (rename in dashboard when ready)
# https://nhlosagycvihmnbeuyag.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Case update API (agent posts live case packets here)
CASEFLOW_API_URL=http://localhost:3000

# TrueFoundry gateway (all LLM calls)
TRUEFOUNDRY_GATEWAY_URL=https://gateway.truefoundry.ai
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_PROJECT_ID=
QWEN_MODEL_ID=qwen/qwen3-32b

# Direct OpenAI (optional — agent uses this for dialogue primary when set)
OPENAI_DIRECT_API_KEY=
OPENAI_DIRECT_MODEL=gpt-4.1-mini
OPENAI_API_KEY=

# Twilio (server routes)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_FIRM_TEST_NUMBER=

# AWS S3 (server routes) + Bedrock gateway fallback (same IAM keys)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
AWS_DEFAULT_REGION=us-west-2
AWS_S3_BUCKET=caseflow-cases-dev
AWS_S3_SENSITIVE_BUCKET=caseflow-sensitive
AWS_KMS_KEY_ID=
CASEFLOW_DELETE_HMAC_SECRET=caseflow-demo-delete
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_FALLBACK_MODEL=us.amazon.nova-lite-v1:0

# MiniMax (dev tune panel + optional direct TTS preview)
MINIMAX_API_KEY=
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_VOICE_ID_ES=Spanish_SereneWoman
MINIMAX_VOICE_ID_EN=voice_agent_Female_Phone_4
MINIMAX_SPEED=1.0
MINIMAX_VOLUME=1.0
MINIMAX_PITCH=0
MINIMAX_EMOTION=neutral
MINIMAX_BASE_URL=https://api.minimax.io

# Internally used environment variables
NEXT_PUBLIC_APP_CONFIG_ENDPOINT=
SANDBOX_ID=
